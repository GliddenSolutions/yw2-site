<script>
  const siteHeader = document.querySelector<HTMLElement>('#navbar');
  const hamburger = document.querySelector<HTMLButtonElement>('#hamburger-btn');
  const nav = document.querySelector<HTMLElement>('#primary-nav');

  if (siteHeader && hamburger && nav) {
    const updateHeader = () => {
      const progress = Math.min(window.scrollY / 80, 1);
      const navbar = siteHeader.querySelector<HTMLElement>('.navbar');

      if (progress >= 1) {
        siteHeader.classList.add('scrolled');
        navbar?.style.removeProperty('background');
        navbar?.style.removeProperty('border-color');
        navbar?.style.removeProperty('box-shadow');
      } else {
        siteHeader.classList.remove('scrolled');
        if (navbar) {
          navbar.style.background = `rgba(255, 255, 255, ${progress})`;
          navbar.style.borderColor = `rgba(209, 218, 255, ${progress})`;
          navbar.style.boxShadow = progress > 0
            ? `0 2px ${Math.round(progress * 16)}px rgba(0, 23, 69, ${progress * 0.07})`
            : 'none';
        }
      }

      let currentSection = '';
      document.querySelectorAll<HTMLElement>('section[id]').forEach((section) => {
        if (section.getBoundingClientRect().top <= 130) currentSection = section.id;
      });

      nav.querySelectorAll<HTMLAnchorElement>('.nav-link').forEach((link) => {
        link.classList.toggle('active', link.getAttribute('href') === `#${currentSection}`);
      });
    };

    const closeMenu = () => {
      siteHeader.classList.remove('nav-open');
      hamburger.setAttribute('aria-expanded', 'false');
    };

    hamburger.addEventListener('click', () => {
      const open = siteHeader.classList.toggle('nav-open');
      hamburger.setAttribute('aria-expanded', String(open));
    });

    nav.querySelectorAll('.nav-link').forEach((link) => link.addEventListener('click', closeMenu));

    document.addEventListener('click', (event) => {
      if (siteHeader.classList.contains('nav-open') && !siteHeader.contains(event.target as Node)) {
        closeMenu();
      }
    });

    window.addEventListener('scroll', updateHeader, { passive: true });
    updateHeader();
  }
</script>
